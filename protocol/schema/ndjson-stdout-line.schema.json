{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NDJSON stdout event line (geo-stream)",
  "description": "One JSON object per line. Matches NdjsonEvent from stdin-stdout.",
  "oneOf": [
    {
      "type": "object",
      "required": ["event", "id", "zone", "t"],
      "properties": {
        "event": { "const": "enter" },
        "id": { "type": "string" },
        "zone": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "zone", "t"],
      "properties": {
        "event": { "const": "exit" },
        "id": { "type": "string" },
        "zone": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "circle", "t"],
      "properties": {
        "event": { "const": "approach" },
        "id": { "type": "string" },
        "circle": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "circle", "t"],
      "properties": {
        "event": { "const": "recede" },
        "id": { "type": "string" },
        "circle": { "type": "string" },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["event", "id", "t"],
      "properties": {
        "event": { "const": "assignment_changed" },
        "id": { "type": "string" },
        "region": { "type": ["string", "null"] },
        "t": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  ]
}

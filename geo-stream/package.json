{
  "name": "@jamesholcombe/geo-stream",
  "version": "0.2.0",
  "description": "Native Node.js bindings for the geo-stream geospatial stream processor",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./emitter": {
      "types": "./dist/emitter.d.ts",
      "default": "./dist/emitter.js"
    },
    "./kafka": {
      "types": "./dist/kafka.d.ts",
      "default": "./dist/kafka.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "default": "./dist/redis.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "napi build --platform --release --manifest-path ../crates/adapters/napi/Cargo.toml --output-dir .",
    "build:debug": "napi build --platform --manifest-path ../crates/adapters/napi/Cargo.toml --output-dir .",
    "compile": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'tests/**/*.test.ts'",
    "prepublishOnly": "npm run compile"
  },
  "dependencies": {
    "@types/geojson": "^7946.0.16"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4",
    "typescript": "^5"
  },
  "napi": {
    "binaryName": "geo_events",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesholcombe/geo-stream"
  },
  "keywords": [
    "geofence",
    "streaming",
    "geospatial",
    "location",
    "events",
    "spatial",
    "napi",
    "native"
  ],
  "engines": {
    "node": ">=18"
  }
}
